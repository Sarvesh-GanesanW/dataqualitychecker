FROM public.ecr.aws/lambda/python:3.12

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    QUALIPILOT_JSON_LOGS=1

# keep this minimal — lambda pulls boto3 from the runtime so we only
# install our own wheel and the bedrock extra
COPY pyproject.toml README.md LICENSE ${LAMBDA_TASK_ROOT}/
COPY src ${LAMBDA_TASK_ROOT}/src

RUN pip install --no-cache-dir \
    "${LAMBDA_TASK_ROOT}[bedrock]" --target "${LAMBDA_TASK_ROOT}"

CMD ["qualipilot.lambda_handler.handler"]
